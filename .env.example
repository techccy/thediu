# LLM API Configuration
# Copy this file to .env and fill in your API keys

# Required: Your LLM API key (e.g., OpenAI API key)
CCY_API_KEY=sk-your-api-key-here

# Optional: LLM API base URL (default: https://api.openai.com/v1)
# CCY_API_BASE=https://api.openai.com/v1

# Optional: LLM model name (default: gpt-4)
# CCY_MODEL=gpt-4
